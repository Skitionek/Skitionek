h3(align="center") 🏆 GitHub Trophies
p(align="center")
    a(href="https://github.com/ryo-ma/github-profile-trophy")
        +variable-picture(
            "https://github-profile-trophy.vercel.app/",
            {
                username: 'skitionek',
                rank: '-C,-B',
                row: 1,
                column: -1,
                'margin-w': 15,
                'margin-h': 15,
                'no-bg': true,
                'no-frame': true
            }
        )(
            prefers-color-scheme={
                'dark': { 'theme': 'darkhub' },
                'light': { 'theme': 'light' }
            }
            alt="skitionek"
        )


//- template.pug
-
    var style = {
        accent: '2F80ED'
    }
    var username = 'Skitionek'

include utils.pug
include variable-images/github-readme-stats.pug
include variable-images/github-readme-streak-stats.pug

h1(align="center") 
    | Hi, I'm Dominik
p(align="center")
    img(src="https://komarev.com/ghpvc/?username=skitionek&label=Profile%20views&color=2F80ED&style=for-the-badge" alt="skitionek")
    | 
    img(src="https://img.shields.io/github/followers/skitionek?label=Followers&style=for-the-badge&color=2F80ED" alt="followers")
    | 
    img(src="https://img.shields.io/github/stars/skitionek?label=Stars&style=for-the-badge&color=2F80ED" alt="stars")
|
|
h3(align="center") Pinned Repositories
p(align="center")
    +github-readme-stats({
        kind: 'pin',
        username: 'SBRG',
        repo: 'lifelike'
    })
    +github-readme-stats({
        kind: 'pin',
        username: 'Skitionek',
        repo: 'notify-microsoft-teams'
    })
+hr
h3(align="center") GitHub Stats & Activity
p(align="center")
    +github-readme-streak-stats
    br
    +github-readme-stats({
        custom_title: 'Total contributions',
        include_all_commits: true
    })
    |  
    +github-readme-stats({
        kind: 'top-langs',
        layout: 'compact',
        langs_count: 10
    })
    br
|
|
h3(align="center") Contribution Graph
p(align="center")
    picture
        source(
            media="(prefers-color-scheme: dark)"
            srcset="https://raw.githubusercontent.com/Skitionek/Skitionek/output/github-contribution-grid-snake-dark.svg"
        )
        source(
            media="(prefers-color-scheme: light)"
            srcset="https://raw.githubusercontent.com/Skitionek/Skitionek/output/github-contribution-grid-snake.svg"
        )
        img(
            alt="github contribution grid snake animation"
            src="https://raw.githubusercontent.com/Skitionek/Skitionek/output/github-contribution-grid-snake.svg"
        )
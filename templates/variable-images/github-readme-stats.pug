-
    var github_readme_stats = {
        'username': username,
        'bg_color': '00000000',
        'hide_border': true,
        'count_private': true
    }

mixin github-readme-stats(options={})
    +variable-picture(
        'https://github-readme-stats.vercel.app/api' + (options.kind ? `/${options.kind}/` : ''),
        merge(
            github_readme_stats,
            ommit(options, 'kind')
        )
        )(
        prefers-color-scheme={
            'dark': { 'theme': 'dark' }
        }
    )&attributes(attributes)

-
    function object_to_query(obj) {
        return '?' + new URLSearchParams(obj)
    }
    function merge(...objs) {
        return Object.assign({}, ...objs)
    }
    function ommit(obj, ...keys) {
        return Object.fromEntries(Object.entries(obj).filter(([key]) => !keys.includes(key)))
    }
    function pick(obj, ...keys) {
        return Object.fromEntries(Object.entries(obj).filter(([key]) => keys.includes(key)))
    }

mixin a()
    a&attributes(merge(
        {target: '_blank', rel: 'noreferrer'},
        attributes
    ))
        if block
            block
mixin img()
    if attributes.href
        +a&attributes(pick(attributes, 'href', 'target', 'rel'))
            img&attributes(ommit(attributes, 'href', 'target', 'rel'))
    else
        img&attributes(attributes)

mixin variable-picture(src, options={})
    if attributes['dark-mode'] || attributes['light-mode']
        +img&attributes(merge(
            ommit(attributes, 'dark-mode', 'light-mode'),
            {
                src: src + object_to_query(merge(
                    options,
                    (attributes['dark-mode'] || {})
                )) + '#gh-dark-mode-only',
                href: (attributes.href || '') + '#gh-dark-mode-only',
                alt: (attributes.alt || '') + '-Dark'
            }
        ))
        +img&attributes(merge(
            ommit(attributes, 'dark-mode', 'light-mode'),
            {
                src: src + object_to_query(merge(
                    options,
                    (attributes['light-mode'] || {})
                )) + '#gh-light-mode-only',
                href: (attributes.href || '') + '#gh-light-mode-only',
                alt: (attributes.alt || '') + '-Light'
            }
        ))
    else
        +img&attributes(merge(
            ommit(attributes, 'dark-mode', 'light-mode'),
            {src: src + object_to_query(options)}
        ))

mixin hr()
    hr
    |
    |
